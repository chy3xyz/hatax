{
  "name": "hatax-admin",
  "version": "1.2.0",
  "description": "Full-stack admin — Vite + Alpine + HTMX + Tailwind frontend, Hono API backend (JWT + CSRF + HTML fragments).",
  "type": "module",
  "license": "MIT",
  "author": "HatTax",
  "keywords": [
    "admin-dashboard",
    "hono",
    "alpinejs",
    "htmx",
    "tailwindcss",
    "vite",
    "fullstack"
  ],
  "scripts": {
    "dev": "vite",
    "dev:server": "node --watch server/index.js",
    "dev:full": "concurrently -n web,api -c cyan,magenta \"npm run dev\" \"npm run dev:server\"",
    "server": "node server/index.js",
    "start": "NODE_ENV=production node server/index.js",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint main.js src server --ext .js",
    "format": "prettier --write \"**/*.{js,html,css,md,json}\" --ignore-path .gitignore"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.8",
    "alpinejs": "^3.14.7",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "dotenv": "^17.4.2",
    "echarts": "^6.1.0",
    "hono": "^4.12.28",
    "htmx.org": "^1.9.12",
    "jose": "^6.2.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "autoprefixer": "^10.4.20",
    "concurrently": "^10.0.3",
    "eslint": "^9.18.0",
    "globals": "^15.14.0",
    "postcss": "^8.5.1",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.17",
    "vite": "^6.0.11"
  }
}
